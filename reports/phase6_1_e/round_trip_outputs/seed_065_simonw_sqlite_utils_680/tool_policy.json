{
  "allow_network": false,
  "allow_write": false,
  "allowed_paths": [],
  "allowed_tools": [
    "pytest"
  ],
  "deny_patterns": [
    ".env",
    ".env.*",
    "*.key",
    "*.pem",
    "*secret*",
    "*.token",
    ".git/config",
    ".git/hooks/*",
    "id_rsa",
    "id_ed25519"
  ],
  "max_output_chars_per_tool": 8000,
  "max_tool_calls": 5,
  "max_total_runtime_s": 60,
  "repo_root": "."
}
